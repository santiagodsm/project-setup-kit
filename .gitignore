# Testbed — throwaway projects used to exercise the chain. Regenerable.
# Kept OUTSIDE this directory (../.project-setup-kit-testbed) because plugin
# install copies the directory tree, not the git tree: anything sitting here
# ships to every user who installs the kit, gitignored or not.
_testbed/

# Audit reports — regenerable by re-running the linter/doctor
HARNESS_DOCTOR.md
PLAN_LINT.md

# Secrets. The real Pushover credentials live in ~/.claude/pushover.env, outside
# every repo, so no `git add` can reach them. A project-local .env is only for
# overriding that — it is ignored here and in every harness this kit generates.
.env
.env.*
!.env.example
*.env
!*.env.example

.DS_Store
