# Pushover credentials for the agent harness.
#
# Copy this to ~/.claude/pushover.env and fill in your two values:
#
#     cp scripts/pushover.env.example ~/.claude/pushover.env
#     chmod 600 ~/.claude/pushover.env
#
# ~/.claude/ is outside every repo, so one copy serves the kit AND every project
# it generates, and no `git add` can ever reach it.
#
# A project-local ./.env with these same two keys overrides the home copy — use
# that only when one project needs a different Pushover application. ./.env is
# gitignored here and in every generated repo.
#
# Where the values come from:
#   PUSHOVER_USER   pushover.net, front page after login — "Your User Key".
#                   30 characters. NOT your email address.
#   PUSHOVER_TOKEN  pushover.net/apps/build — create an application (call it
#                   whatever you like, "claude-code" is fine). 30 characters.
#
# Verify with:  scripts/notify.sh selftest

PUSHOVER_USER=replace-me-with-your-30-char-user-key
PUSHOVER_TOKEN=replace-me-with-your-30-char-app-token

# Optional. Set to 1 to mute every push without removing the wiring.
# PUSHOVER_DISABLED=0
